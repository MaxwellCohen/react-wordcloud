{
  "name": "react-wordcloud",
  "version": "1.2.7",
  "description": "Simple React + D3 wordcloud component with powerful features.",
  "license": "MIT",
  "homepage": "https://react-wordcloud.netlify.com/",
  "repository": "chrisrzhou/react-wordcloud",
  "bugs": "https://github.com/chrisrzhou/react-wordcloud/issues",
  "author": "Chris Zhou <chrisrzhou@pm.me> (https://chrisrzhou.io)",
  "keywords": [
    "react",
    "wordcloud",
    "visualization",
    "d3"
  ],
  "scripts": {
    "build": "rolldown -c",
    "clean": "rm -rf dist",
    "lint": "oxlint . --fix && tsc",
    "prepare": "npm run clean; npm run build"
  },
  "main": "dist/index.js",
  "module": "dist/index.module.js",
  "source": "index.js",
  "typings": "types/index.d.ts",
  "files": [
    "dist",
    "types/index.d.ts"
  ],
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-cloud": "^1.2.9",
    "d3-dispatch": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.1",
    "lodash.debounce": "^4.0.8",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@types/d3-array": "^2.12.8",
    "@types/d3-cloud": "^1.2.9",
    "@types/d3-scale": "^2.2.10",
    "@types/d3-scale-chromatic": "^1.5.4",
    "@types/d3-selection": "^1.4.7",
    "@types/lodash.debounce": "^4.0.9",
    "@types/seedrandom": "^2.4.34",
    "oxlint": "^1.0.0",
    "rolldown": "^1.0.0-rc",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "prettier": {
    "bracketSpacing": true,
    "jsxBracketSameLine": true,
    "trailingComma": "all",
    "useTabs": false
  }
}
